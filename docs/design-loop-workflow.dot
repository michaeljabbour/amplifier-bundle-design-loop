// Plain-language workflow of the judge (today's single-pass shape). UTF-8 glyphs.
digraph design_loop {
  rankdir=LR; bgcolor="white"; pad=0.45; nodesep=0.5; ranksep=0.8;
  fontname="Helvetica"; labelloc="t"; fontsize=22; fontcolor="#1A1A1A";
  label=<<b>How the design judge works (today)</b><br/><font point-size="13" color="#6B6357">One pass — you decide whether to run it again</font>>;
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=13,
        color="#D8D2C7", fillcolor="#F5F2EC", fontcolor="#1A1A1A", margin="0.22,0.16", penwidth=1.2];
  edge [color="#9A9182", penwidth=1.5, arrowsize=0.85, fontname="Helvetica", fontsize=11, fontcolor="#6B6357"];
  share [label="You share a design\n(web page, link,\nor screenshot)", fillcolor="#ECE7DD"];
  pic1  [label="Takes a picture of it"];
  score [label="Decides a score for each\nof 8 qualities (0–4)", fillcolor="#F1DDD2", color="#C2613F"];
  pick  [label="Decides which problems\nmatter most to fix", fillcolor="#F1DDD2", color="#C2613F"];
  rebuild [label="Redesigns it into\nan improved version", fillcolor="#F1DDD2", color="#C2613F"];
  pic2  [label="Takes a picture of the\nimproved version"];
  report [label="Hands you a report:\nscore · fixes · before → after", fillcolor="#2F6F6A", fontcolor="white", color="#24544F"];
  check [shape=diamond, label="Good\nenough?", fillcolor="#FBF6EE", color="#C2613F", margin="0.05,0.02"];
  done  [label="Done", fillcolor="#E4ECE0", color="#7FA487"];
  share -> pic1 -> score -> pick -> rebuild -> pic2 -> report -> check;
  check -> done [label="yes"];
  check -> pic1 [label="no — judge the\nimproved version", style=dashed, color="#C2613F", fontcolor="#C2613F", constraint=false];
}
